# Copy this file to .env and fill in your values.

# --- Hermes API gateway ---
# URL of the existing Hermes API server. For a same-machine install, the default
# is usually correct.
HERMES_API_URL=http://127.0.0.1:8642

# Bearer token used by this interface server when it calls Hermes, if your
# Hermes API server requires one. Leave blank when Hermes is local/no-auth.
HERMES_API_KEY=

# --- iOS interface server ---
# Host the iOS interface server binds to. Use 0.0.0.0 when an iPhone will reach
# this machine over LAN, VPN, or Tailscale.
HERMES_INTERFACE_HOST=0.0.0.0

# Port the iOS interface server listens on.
HERMES_INTERFACE_PORT=3001

# Bearer token the iOS app must send to this interface server. Generate a long,
# random value during install.
HERMES_INTERFACE_KEY=

# --- Storage paths ---
# SQLite database for iOS-visible chats/projects/messages.
# Defaults to <repo>/data/chats.db
# HERMES_INTERFACE_DB=/path/to/chats.db

# Existing Hermes state database. Defaults to ~/.hermes/state.db.
# HERMES_STATE_DB=/path/to/state.db

# Existing Hermes memory directory. Defaults to ~/.hermes/memories.
# HERMES_MEMORIES_PATH=/path/to/memories

# Existing Hermes config. Defaults to ~/.hermes/config.yaml.
# HERMES_CONFIG_PATH=/path/to/config.yaml

# Optional channel-owned voice picker metadata. This does not modify Hermes and
# does not change Hermes defaults; it only tells the iOS channel which
# provider-specific voices can be selected.
# HERMES_VOICE_INVENTORY_PATH=/path/to/voice-inventory.json
